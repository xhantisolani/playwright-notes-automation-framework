{
  "name": "playwright-notes-automation-framework",
  "version": "1.0.0",
  "description": "A beginner-to-intermediate Playwright TypeScript automation framework for the ExpandTesting Notes App and Notes API.",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "test:api": "playwright test --project=api",
    "test:ui": "playwright test --project=chromium --grep @ui",
    "test:e2e": "playwright test --project=chromium --grep @e2e",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:accessibility": "playwright test tests/ui/accessibility --project=chromium",
    "test:mocking": "playwright test tests/ui/mocking --project=chromium",
    "test:visual": "cross-env RUN_VISUAL=true playwright test tests/ui/visual --project=chromium",
    "test:visual:update": "cross-env RUN_VISUAL=true playwright test tests/ui/visual --project=chromium --update-snapshots",
    "test:journey": "cross-env RUN_JOURNEY=true playwright test tests/journeys --project=chromium",
    "test:journey:headed": "cross-env RUN_JOURNEY=true playwright test tests/journeys --project=chromium --headed",
    "test:nightly": "cross-env RUN_JOURNEY=true playwright test --grep @nightly",
    "report": "node scripts/show-playwright-report.mjs",
    "report:summary": "node scripts/summarize-report.mjs",
    "report:allure": "node scripts/allure-report.mjs",
    "report:allure:open": "node scripts/allure-report.mjs --open",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "install:browsers": "playwright install"
  },
  "keywords": [
    "playwright",
    "typescript",
    "test-automation",
    "api-testing",
    "qa"
  ],
  "author": "Xhanti Solani",
  "license": "MIT",
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.0",
    "allure-commandline": "^2.43.0",
    "allure-playwright": "^3.10.2",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.6.0",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  }
}
