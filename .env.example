# ExpandTesting Notes UI and API targets.
BASE_URL=https://practice.expandtesting.com/notes/app
API_BASE_URL=https://practice.expandtesting.com/notes/api

# Optional: use your own practice account.
# If these are omitted, the auth setup creates a temporary API user for the run.
TEST_USER_NAME=Playwright Learner
TEST_USER_EMAIL=
TEST_USER_PASSWORD=

# Set to true if you want to keep the temporary account after a full test run.
KEEP_TEST_ACCOUNT=false
